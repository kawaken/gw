#!/usr/bin/env zsh

# ─── Internal subcommands (called by fzf) ──────────────────

case "$1" in
    --toggle)
        # args: <line_index(0-based)> <state_file>
        local line_num=$(( $2 + 1 ))
        local sf="$3"
        local tmp="${sf}.tmp"
        awk -v n="$line_num" -F'\t' 'BEGIN{OFS="\t"} {
            if (NR == n) {
                if ($1 == "-") $1 = "copy"
                else if ($1 == "copy") $1 = "symlink"
                else if ($1 == "symlink") $1 = "-"
                else if ($1 == "missing") $1 = "-"
            }
            print
        }' "$sf" > "$tmp" && mv "$tmp" "$sf"
        exit 0
        ;;
    --render)
        # args: <state_file>
        awk -F'\t' '{
            if ($1 == "copy")    tag = "[copy]   "
            else if ($1 == "symlink") tag = "[symlink]"
            else if ($1 == "missing") tag = "[missing]"
            else                 tag = "[-]      "
            printf "%s %s\n", tag, $2
        }' "$2"
        exit 0
        ;;
esac

# ─── Main ──────────────────────────────────────────────────

if ! command -v fzf > /dev/null 2>&1; then
    echo "Error: fzf is not installed" >&2
    exit 1
fi

repo_root=$(git worktree list 2>/dev/null | head -n 1 | awk '{print $1}')
if [[ -z "$repo_root" ]]; then
    echo "Error: not in a git repository" >&2
    exit 1
fi

choice_dir=""
if [[ "$1" == "--choice" ]]; then
    choice_dir="$2"
    if [[ -z "$choice_dir" ]]; then
        echo "Error: --choice requires a directory argument" >&2
        exit 1
    fi
    if [[ ! -d "$repo_root/$choice_dir" ]]; then
        echo "Error: directory not found: $choice_dir" >&2
        exit 1
    fi
fi

state_file="${TMPDIR:-/tmp}/gw-sync-edit.$$"
trap 'rm -f "$state_file" "${state_file}.tmp"' EXIT INT TERM

sync_file="${repo_root}/.gw/config"

typeset -A seen
if [[ -f "$sync_file" ]]; then
    local lines=(${(f)"$(< "$sync_file")"})
    local line type filepath
    for line in "${lines[@]}"; do
        [[ -z "$line" ]] && continue
        case "$line" in
            copy:*)    type="copy";    filepath="${${line#copy:}## }" ;;
            symlink:*) type="symlink"; filepath="${${line#symlink:}## }" ;;
            *)         type="copy";    filepath="$line" ;;
        esac
        [[ -z "$filepath" ]] && continue
        [[ ! -e "$repo_root/$filepath" ]] && type="missing"
        seen[$filepath]=1
        printf '%s\t%s\n' "$type" "$filepath" >> "$state_file"
    done
fi

if [[ -n "$choice_dir" ]]; then
    local files=(${(f)"$(find "$repo_root/$choice_dir" -type f | sort | sed "s|^${repo_root}/||")"})
    if (( ${#files[@]} > 50 )); then
        echo "Error: too many files (${#files[@]}), max 50. Use a more specific directory." >&2
        exit 1
    fi
    local f
    for f in "${files[@]}"; do
        [[ -z "$f" || -n "${seen[$f]}" ]] && continue
        seen[$f]=1
        printf '%s\t%s\n' "-" "$f" >> "$state_file"
    done
fi

if [[ ! -s "$state_file" ]]; then
    echo "No entries to display." >&2
    exit 0
fi

result=$("$0" --render "$state_file" | \
    fzf --ansi \
        --no-multi \
        --height='~50%' \
        --layout=reverse \
        --header='Tab: toggle | Enter: save | ESC: cancel' \
        --bind "tab:execute-silent($0 --toggle {n} $state_file)+reload($0 --render $state_file)" \
        --bind 'enter:become(echo __SAVE__)')

[[ "$result" != "__SAVE__" ]] && exit 0

tmp_out="${sync_file}.tmp.$$"
awk -F'\t' '$1 == "copy" || $1 == "symlink" { printf "%s: %s\n", $1, $2 }' "$state_file" > "$tmp_out"

if [[ -s "$tmp_out" ]]; then
    mv "$tmp_out" "$sync_file"
    cat "$sync_file"
else
    rm -f "$tmp_out" "$sync_file"
fi
