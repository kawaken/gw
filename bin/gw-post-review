#!/usr/bin/env zsh
# Helper: launch Claude Code in review mode
# Usage: gw-post-review <worktree_path> <pr_number> <pr_url>
#
# Example .gw/hooks/post-review:
#   #!/usr/bin/env zsh
#   ~/dotfiles/gw/gw-post-review "$@"

worktree_path="$1"
pr_number="$2"
pr_url="$3"

command -v claude &> /dev/null || return 0

review_prompt="このセッションはレビュー専用です。コードの修正の必要はありません。またPR本体へのコメントも必要ありません。指摘事項があればこちらで教えてください。差分はPRの内容を確認し、PR以外のファイルについての指摘は必要ありません。"

claude --permission-mode plan --append-system-prompt "$review_prompt" "PR #${pr_number} のレビューを開始してください。PR URL: ${pr_url}"
