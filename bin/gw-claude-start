#!/usr/bin/env zsh
# Start Claude Code session with worktree task name
# Env: GW_SUBCOMMAND - used to find .gw/prompts/<subcommand>.md
dir="${1:A}"
task_name="${GW_DESCRIPTION:-$(basename "$dir")}"

cd "$dir"
main_repo=$(git worktree list | head -n 1 | awk '{print $1}')
prompt_file="${main_repo}/.gw/prompts/${GW_SUBCOMMAND}.md"

if [[ -n "$GW_SUBCOMMAND" ]] && [[ -f "$prompt_file" ]]; then
    claude --name "$task_name" --append-system-prompt "$(cat "$prompt_file")"
else
    claude --name "$task_name"
fi
